# Supabase Configuration
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
# Service role key — used server-side to bypass RLS (keep secret, never expose to frontend)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Direct Postgres connection — used by run-sql.ts script only
# Find it in: Supabase Dashboard → Project Settings → Database → Connection string (URI)
# Use the "Session mode" URI (port 5432) for scripts, or "Transaction mode" (port 6543) for pooling
SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Server Configuration
PORT=4000

# Environment
NODE_ENV=development
